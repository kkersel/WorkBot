# ============================================================
# Telegram
# ============================================================
TELEGRAM_BOT_TOKEN=

# Primary group chat ID (negative number for groups)
PRIMARY_CHAT_ID=

# ============================================================
# Supabase (Postgres)
# ============================================================
# Full Postgres connection string — for asyncpg (bot).
# Settings > Database > Connection string > "URI" with "use connection pooling" OFF
# pgbouncer 6543 is OK for asyncpg too if prepared_statement_cache_size=0.
DATABASE_URL=

# For @supabase/supabase-js (webapp, server-side only)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# AI (pick one — we default to Groq)
# ============================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gemini via Google AI Studio
GEMINI_API_KEY=

# ============================================================
# WebApp
# ============================================================
# Public URL of the deployed Next.js app (used in BotFather and by the bot)
WEBAPP_URL=

# Node runtime (for webapp)
NEXT_PUBLIC_APP_URL=

# Telegram user IDs that see the admin section in the webapp
# (today's ping buttons, global gym poll time, etc.). Comma or
# whitespace separated.
ADMIN_USER_IDS=
